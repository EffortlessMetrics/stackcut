{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stackcut.dev/schema/stackcut.override.schema.json",
  "title": "stackcut overrides",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "must_link": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "members"
        ],
        "properties": {
          "members": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "force_members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "member",
          "slice"
        ],
        "properties": {
          "member": {
            "type": "string"
          },
          "slice": {
            "type": "string"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "rename_slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "must_order": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "before",
          "after"
        ],
        "properties": {
          "before": {
            "type": "string"
          },
          "after": {
            "type": "string"
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "default": []
    }
  },
  "additionalProperties": false
}
